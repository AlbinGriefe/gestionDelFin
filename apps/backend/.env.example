NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173
DATABASE_URL="mysql://app_user:app_password@localhost:3306/apocalypse_db?allowPublicKeyRetrieval=true"

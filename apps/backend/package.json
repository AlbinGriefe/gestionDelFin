{
  "name": "@gestiondelfin/backend",
  "version": "1.0.0",
  "description": "Backend API for gestionDelFin.",
  "main": "dist/src/server.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "seed": "tsx prisma/seed.ts",
    "prisma:validate": "npx.cmd prisma validate --config prisma/prisma.config.ts",
    "prisma:pull": "npx.cmd prisma db pull --config prisma/prisma.config.ts",
    "prisma:format": "npx.cmd prisma format --config prisma/prisma.config.ts",
    "prisma:generate": "npx.cmd prisma generate --config prisma/prisma.config.ts",
    "prisma:sync": "npm run prisma:pull && npm run prisma:format && npm run prisma:generate"
  },
  "keywords": [
    "express",
    "prisma",
    "jwt",
    "mysql",
    "api"
  ],
  "author": "Equipo gestionDelFin",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.2",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.4.1",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mariadb": "^3.5.2",
    "zod": "^4.3.6"
  }
}

{
  "name": "gestiondelfin",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo del proyecto gestionDelFin con frontend, backend, Prisma y documentacion.",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f mysql",
    "frontend:install": "npm --prefix apps/frontend install",
    "backend:install": "npm --prefix apps/backend install",
    "install:all": "npm run frontend:install && npm run backend:install",
    "frontend:dev": "npm --prefix apps/frontend run dev",
    "frontend:build": "npm --prefix apps/frontend run build",
    "backend:prisma:validate": "npm --prefix apps/backend run prisma:validate",
    "backend:prisma:sync": "npm --prefix apps/backend run prisma:sync",
    "backend:prisma:generate": "npm --prefix apps/backend run prisma:generate"
  },
  "keywords": [
    "monorepo",
    "react",
    "express",
    "prisma",
    "mysql"
  ],
  "author": "Equipo gestionDelFin",
  "license": "ISC",
  "type": "commonjs"
}
